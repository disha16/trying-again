{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/quality-check",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 20 * * *"
    }
  ]
}
