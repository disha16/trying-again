{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/quality-check",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 20 * * *"
    }
  ]
}